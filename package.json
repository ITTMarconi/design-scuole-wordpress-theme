{
  "name": "design-scuole-wordpress-theme",
  "version": "2.5.1",
  "description": "Tema Wordpress delle Scuole Italiane",
  "main": "index.js",
  "scripts": {
    "build": "npm run minify:css && npm run minify:js && npm run tail:build",
    "version": "node scripts/config-sync.js && git add style.css && git add README.md",
    "postversion": "echo \"You can now publish your tag with 'git push --follow-tags'\"",
    "minify:css": "node scripts/minify-css.js",
    "minify:js": "node scripts/minify-js.js",
    "tail:watch": "tailwindcss -i ./assets-src/css/tail.css -o ./assets/css/tail.css --watch",
    "tail:build": "tailwindcss -i ./assets-src/css/tail.css -o ./assets/css/tail.css --minify",
    "build:css": "npm-run-all --parallel tail:build minify:css",
    "import:md": "node scripts/md-import.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/italia/design-scuole-wordpress-theme.git"
  },
  "author": "Presidenza del Consiglio dei Ministri",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/italia/design-scuole-wordpress-theme/issues"
  },
  "homepage": "https://github.com/italia/design-scuole-wordpress-theme#readme",
  "dependencies": {
    "bootstrap-italia": "^2.0.9"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "clean-css-cli": "^5.6.1",
    "form-data": "^4.0.5",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.2",
    "npm-run-all": "^4.1.5",
    "replace-in-file": "^6.3.5",
    "tailwindcss": "^4.2.1",
    "tailwindcss-motion": "^1.1.1",
    "uglify-js": "^3.17.4"
  }
}

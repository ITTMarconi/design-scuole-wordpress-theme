# Copia questo file in .env e compila i valori.
# Il file .env non viene mai committato (è in .gitignore).
#
# Come ottenere la Application Password:
#   WP Admin → Utenti → il tuo profilo → "Password dell'applicazione"
#   Scegli un nome (es. "importer"), clicca "Aggiungi" e copia la password.

WP_URL=https://dev.ittm.it
WP_USER=admin
WP_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx

# Imposta true se WP_URL usa un certificato SSL self-signed (ambienti di sviluppo).
# Non usare mai true in produzione.
WP_INSECURE=false
